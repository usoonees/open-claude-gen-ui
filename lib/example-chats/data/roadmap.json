            ],
            "widgetCode": "<style>\n  .phase-row { display: flex; gap: 16px; align-items: stretch; margin-bottom: 4px; cursor: pointer; }\n  .phase-marker { display: flex; flex-direction: column; align-items: center; width: 40px; flex-shrink: 0; }\n  .phase-dot { width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 500; flex-shrink: 0; border: 2px solid var(--color-border-secondary); background: var(--color-background-secondary); color: var(--color-text-secondary); transition: all .2s; }\n  .phase-dot.active { border-color: var(--color-text-info); background: var(--color-background-info); color: var(--color-text-info); }\n  .phase-dot.done { border-color: var(--color-text-success); background: var(--color-background-success); color: var(--color-text-success); }\n  .phase-line { flex: 1; width: 2px; background: var(--color-border-tertiary); min-height: 8px; transition: background .2s; }\n  .phase-line.done { background: var(--color-text-success); }\n  .phase-card { flex: 1; border: 0.5px solid var(--color-border-tertiary); border-radius: var(--border-radius-lg); padding: 14px 16px; background: var(--color-background-primary); transition: all .2s; margin-bottom: 4px; }\n  .phase-card:hover { border-color: var(--color-border-secondary); }\n  .phase-card.active { border-color: var(--color-text-info); border-width: 1.5px; }\n  .phase-card.done { border-color: var(--color-text-success); border-width: 1.5px; }\n  .phase-header { display: flex; justify-content: space-between; align-items: center; }\n  .phase-title { font-size: 15px; font-weight: 500; color: var(--color-text-primary); }\n  .phase-time { font-size: 12px; color: var(--color-text-tertiary); background: var(--color-background-secondary); padding: 2px 8px; border-radius: var(--border-radius-md); }\n  .phase-desc { font-size: 13px; color: var(--color-text-secondary); margin: 6px 0 0; line-height: 1.5; }\n  .phase-detail { overflow: hidden; max-height: 0; transition: max-height .35s ease, margin .2s; }\n  .phase-detail.open { max-height: 500px; margin-top: 12px; }\n  .skill-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px 12px; }\n  .skill-item { display: flex; align-items: center; gap: 6px; font-size: 13px; color: var(--color-text-secondary); }\n  .skill-check { width: 14px; height: 14px; border-radius: 3px; border: 1px solid var(--color-border-secondary); flex-shrink: 0; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 10px; background: var(--color-background-primary); color: transparent; transition: all .15s; }\n  .skill-check.checked { background: var(--color-background-success); border-color: var(--color-text-success); color: var(--color-text-success); }\n  .tag-row { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 10px; }\n  .tag { font-size: 11px; padding: 2px 8px; border-radius: var(--border-radius-md); }\n  .tag-tool { background: var(--color-background-info); color: var(--color-text-info); }\n  .tag-lib { background: var(--color-background-warning); color: var(--color-text-warning); }\n  .progress-bar { height: 6px; background: var(--color-background-secondary); border-radius: 3px; overflow: hidden; margin-bottom: 20px; }\n  .progress-fill { height: 100%; background: var(--color-text-success); border-radius: 3px; transition: width .4s ease; }\n  .header-row { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 8px; }\n  .header-title { font-size: 18px; font-weight: 500; color: var(--color-text-primary); }\n  .header-stat { font-size: 13px; color: var(--color-text-secondary); }\n</style>\n\n<div style=\"max-width: 640px; margin: 0 auto;\">\n  <div class=\"header-row\">\n    <span class=\"header-title\">Full-stack TypeScript roadmap</span>\n    <span class=\"header-stat\" id=\"stat-label\">0 / 7 phases complete</span>\n  </div>\n  <div class=\"progress-bar\"><div class=\"progress-fill\" id=\"progress-fill\" style=\"width: 0%\"></div></div>\n\n  <div id=\"roadmap\"></div>\n</div>\n\n<script>\nconst phases = [\n  {\n    title: \"TypeScript core\",\n    time: \"3-4 weeks\",\n    desc: \"Master the type system before building anything. This is the foundation everything else rests on.\",\n    skills: [\"Primitive & literal types\", \"Interfaces vs type aliases\", \"Generics & constraints\", \"Utility types (Partial, Pick, Omit)\", \"Discriminated unions\", \"Type guards & narrowing\", \"Declaration files (.d.ts)\", \"Module systems & tsconfig\"],\n    tools: [{ name: \"TypeScript 5.x\", type: \"tool\" }, { name: \"tsx\", type: \"lib\" }]\n  },\n  {\n    title: \"Frontend with React + TS\",\n    time: \"4-5 weeks\",\n    desc: \"Build typed UIs with React. Understand component patterns, state management, and client-side routing.\",\n    skills: [\"Typed props & state\", \"useState / useReducer generics\", \"Context with type safety\", \"Custom hook patterns\", \"React Router with params\", \"Zod for form validation\", \"CSS modules / Tailwind + TS\", \"Component composition patterns\"],\n    tools: [{ name: \"React 19\", type: \"lib\" }, { name: \"Vite\", type: \"tool\" }, { name: \"Zod\", type: \"lib\" }, { name: \"Tailwind\", type: \"lib\" }]\n  },\n  {\n    title: \"Backend with Node + TS\",\n    time: \"4-5 weeks\",\n    desc: \"Build type-safe APIs. Choose a framework, define routes, handle middleware, and structure your server code.\",\n    skills: [\"Express / Hono with TS\", \"Typed request & response objects\", \"Middleware patterns\", \"Error handling & result types\", \"Environment variables (zod)\", \"File-based routing\", \"Streaming responses\", \"WebSocket basics\"],\n    tools: [{ name: \"Hono / Express\", type: \"lib\" }, { name: \"tsx watch\", type: \"tool\" }, { name: \"Zod\", type: \"lib\" }]\n  },\n  {\n    title: \"Database & ORM layer\",\n    time: \"3-4 weeks\",\n    desc: \"Connect your backend to a database with full type safety from schema to query results.\",\n    skills: [\"Prisma / Drizzle setup\", \"Schema-first modeling\", \"Migrations workflow\", \"Typed queries & relations\", \"Connection pooling\", \"Transactions & batch ops\", \"Seed scripts\", \"SQLite for local dev\"],\n    tools: [{ name: \"Prisma / Drizzle\", type: \"lib\" }, { name: \"PostgreSQL\", type: \"tool\" }, { name: \"Docker (for DB)\", type: \"tool\" }]\n  },\n  {\n    title: \"Full-stack integration\",\n    time: \"4-6 weeks\",\n    desc: \"Unify frontend and backend into one type-safe app. Share types end-to-end and add authentication.\",\n    skills: [\"Next.js App Router + TS\", \"Server components vs client\", \"tRPC or server actions\", \"End-to-end type safety\", \"Auth (NextAuth / Clerk)\", \"Session & JWT handling\", \"API design patterns\", \"Monorepo with Turborepo\"],\n    tools: [{ name: \"Next.js 15\", type: \"lib\" }, { name: \"tRPC\", type: \"lib\" }, { name: \"Turborepo\", type: \"tool\" }, { name: \"NextAuth\", type: \"lib\" }]\n  },\n  {\n    title: \"Testing & quality\",\n    time: \"2-3 weeks\",\n    desc: \"Write tests that leverage your types. Unit, integration, and E2E — all in TypeScript.\",\n    skills: [\"Vitest unit testing\", \"Testing Library for React\", \"MSW for API mocking\", \"Integration test patterns\", \"Playwright E2E tests\", \"Coverage & thresholds\", \"ESLint + typescript-eslint\", \"Prettier config\"],\n    tools: [{ name: \"Vitest\", type: \"lib\" }, { name: \"Playwright\", type: \"lib\" }, { name: \"MSW\", type: \"lib\" }, { name: \"eslint\", type: \"tool\" }]\n  },\n  {\n    title: \"Deploy & monitor\",\n    time: \"2-3 weeks\",\n    desc: \"Ship your app to production. Set up CI/CD, containerization, and observability.\",\n    skills: [\"Dockerfile for TS app\", \"CI pipeline (GitHub Actions)\", \"Vercel / Fly.io deploy\", \"Build optimization\", \"Runtime error tracking\", \"Logging & monitoring\", \"Database migrations in CI\", \"Environment management\"],\n    tools: [{ name: \"Vercel / Fly.io\", type: \"tool\" }, { name: \"Docker\", type: \"tool\" }, { name: \"GitHub Actions\", type: \"tool\" }, { name: \"Sentry\", type: \"lib\" }]\n  }\n];\n\nconst skillState = phases.map(() => []);\nconst phaseState = phases.map(() => false); // expanded\nconst container = document.getElementById('roadmap');\n\nfunction render() {\n  container.innerHTML = '';\n  const totalSkills = phases.reduce((s, p) => s + p.skills.length, 0);\n  const checkedSkills = skillState.reduce((s, arr) => s + arr.filter(Boolean).length, 0);\n  const donePhases = phases.filter((_, i) => skillState[i].filter(Boolean).length === phases[i].skills.length).length;\n\n  document.getElementById('progress-fill').style.width = Math.round((checkedSkills / totalSkills) * 100) + '%';\n  document.getElementById('stat-label').textContent = `${donePhases} / ${phases.length} phases complete`;\n\n  phases.forEach((phase, pi) => {\n    const allDone = skillState[pi].filter(Boolean).length === phase.skills.length;\n    const row = document.createElement('div');\n    row.className = 'phase-row';\n    row.innerHTML = `\n      <div class=\"phase-marker\">\n        <div class=\"phase-dot ${allDone ? 'done' : phaseState[pi] ? 'active' : ''}\">${allDone ? '&#10003;' : pi + 1}</div>\n        ${pi < phases.length - 1 ? `<div class=\"phase-line ${allDone ? 'done' : ''}\"></div>` : ''}\n      </div>\n      <div class=\"phase-card ${allDone ? 'done' : phaseState[pi] ? 'active' : ''}\">\n        <div class=\"phase-header\">\n          <span class=\"phase-title\">${phase.title}</span>\n          <span class=\"phase-time\">${phase.time}</span>\n        </div>\n        <p class=\"phase-desc\">${phase.desc}</p>\n        <div class=\"phase-detail ${phaseState[pi] ? 'open' : ''}\" id=\"detail-${pi}\">\n          <div class=\"skill-grid\">\n            ${phase.skills.map((sk, si) => `\n              <div class=\"skill-item\">\n                <div class=\"skill-check ${skillState[pi][si] ? 'checked' : ''}\" data-p=\"${pi}\" data-s=\"${si}\">&#10003;</div>\n                <span>${sk}</span>\n              </div>\n            `).join('')}\n          </div>\n          <div class=\"tag-row\">\n            ${phase.tools.map(t => `<span class=\"tag tag-${t.type}\">${t.name}</span>`).join('')}\n          </div>\n        </div>\n      </div>\n    `;\n\n    const card = row.querySelector('.phase-card');\n    card.addEventListener('click', (e) => {\n      if (e.target.classList.contains('skill-check') || e.target.closest('.skill-check')) return;\n      phaseState[pi] = !phaseState[pi];\n      render();\n    });\n\n    row.querySelectorAll('.skill-check').forEach(el => {\n      el.addEventListener('click', (e) => {\n        e.stopPropagation();\n        const p = parseInt(el.dataset.p);\n        const s = parseInt(el.dataset.s);\n        skillState[p][s] = !skillState[p][s];\n        render();\n      });\n    });\n\n    container.appendChild(row);\n  });\n}\n\nrender();\n</script>"
          },
