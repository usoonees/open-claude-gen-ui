-size: 12px; color: var(--color-text-secondary); }\n  .verdict-item strong { display: block; font-size: 11px; color: var(--color-text-primary); margin-bottom: 2px; }\n  hr.div { border: none; border-top: 0.5px solid var(--color-border-tertiary); margin: 16px 0; }\n</style>\n\n<p class=\"section-label\">Three approaches to LLM customization</p>\n<div class=\"card-row\">\n  <div class=\"appr-card\">\n    <div class=\"appr-tag\" style=\"background: var(--color-background-info); color: var(--color-text-info)\">No training</div>\n    <p class=\"appr-name\">Prompt engineering</p>\n    <p class=\"appr-desc\">Steering model behavior through carefully crafted instructions, examples, and input formatting at inference time.</p>\n  </div>\n  <div class=\"appr-card\">\n    <div class=\"appr-tag\" style=\"background: var(--color-background-secondary); color: var(--color-text-secondary)\">Light training</div>\n    <p class=\"appr-name\">RAG (Retrieval-Augmented Generation)</p>\n    <p class=\"appr-desc\">Connecting the model to external knowledge bases so it retrieves and grounds responses in up-to-date, domain-specific documents.</p>\n  </div>\n  <div class=\"appr-card\">\n    <div class=\"appr-tag\" style=\"background: var(--color-background-warning); color: var(--color-text-warning)\">Full training</div>\n    <p class=\"appr-name\">Fine-tuning</p>\n    <p class=\"appr-desc\">Updating the model's weights on a labeled dataset to instill knowledge, style, or task-specific behavior permanently.</p>\n  </div>\n</div>\n\n<hr class=\"div\">\n\n<p class=\"section-label\">Tradeoff comparison across key dimensions</p>\n<div class=\"legend\">\n  <span><span class=\"legend-dot\" style=\"background:#3266ad\"></span>Prompt engineering</span>\n  <span><span class=\"legend-dot\" style=\"background:#73726c\"></span>RAG</span>\n  <span><span class=\"legend-dot\" style=\"background:#5c936e\"></span>Fine-tuning</span>\n</div>\n\n<div class=\"dim-row\">\n  <span class=\"dim-label\">Setup cost</span